# Copy this file to `.env` (same folder as bot.py) and fill in the values.
# Only the four keys in the "Required" block are mandatory — the bot will not
# start without them. Everything below that has a sensible default.

# --- Required ---
DISCORD_BOT_TOKEN="YOUR_DISCORD_BOT_TOKEN_HERE"
TMDB_API_KEY="YOUR_TMDB_API_KEY_HERE"
ALPHA_VANTAGE_API_KEY="YOUR_ALPHA_VANTAGE_API_KEY_HERE"
OPENWEATHERMAP_API_KEY="YOUR_OPENWEATHERMAP_API_KEY_HERE"

# --- Storage (optional; default shown) ---
# SQLITE_DB_PATH="data/app.db"

# --- Report webhook (optional) ---
# Public base URL used to build per-user webhook links (/settings webhook_link).
# WEBHOOK_BASE_URL="http://localhost:5000"
# If set, incoming webhook POSTs must carry a valid HMAC-SHA256 signature.
# WEBHOOK_SHARED_SECRET=""
# Max accepted request body size in bytes (default 51200 = 50 KB).
# WEBHOOK_MAX_BYTES=51200
# Per-token+IP rate limit for the webhook endpoint.
# WEBHOOK_RATE_LIMIT_PER_MIN=30
# Allow rendering charts via external services in delivered reports.
# ALLOW_EXTERNAL_CHARTS=true

# --- Clockify (optional) ---
# Per-user API keys are linked in Discord via `/clockify config`, so no key goes
# here. Only override the base URL for non-global regions (EU/UK/AU).
# CLOCKIFY_API_BASE_URL="https://api.clockify.me/api/v1"

# --- Timer / Firebase sync (optional, owner-only feature) ---
# FIREBASE_DATABASE_URL=""
# FIREBASE_DATABASE_SECRET=""
# TIMER_OWNER_ID=0
# DISCORD_SYNC_SECRET=""
# TIMER_AUTH_PASSWORD=""
